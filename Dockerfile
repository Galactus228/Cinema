# 1. Выбираем базовый образ с Node.js
FROM node:18-alpine

# 2. Указываем рабочую папку внутри контейнера
WORKDIR /usr/src/app

# 3. Копируем package.json, чтобы установить зависимости
COPY package*.json ./

# 4. Устанавливаем зависимости
RUN npm install

# 5. Копируем все остальные файлы проекта
COPY . .

# 6. Открываем порт, который слушает наше приложение
EXPOSE 3000

# 7. Указываем команду для запуска сервера при старте контейнера
CMD [ "node", "server.js" ]
